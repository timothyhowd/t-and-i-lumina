# Lumina PoC — local environment template.
# Copy to .env.local and fill in the values. .env.local is gitignored.

# DoorDash Portkey gateway API key.
# This routes through cybertron-service-gateway.doordash.team — not the
# public Anthropic API. Get one from the Portkey UI inside the company.
PORTKEY_API_KEY=pk-...

# Optional overrides for the model slugs. Defaults are good guesses;
# adjust if your Portkey "Model Catalog" tab lists different slugs.
# LUMINA_MODEL_OPUS=@anthropic/claude-opus-4-7
# LUMINA_MODEL_HAIKU=@anthropic/claude-haiku-4-5

# Optional override for the gateway base URL. Defaults to the prod URL.
# LUMINA_GATEWAY_BASE_URL=https://cybertron-service-gateway.doordash.team/v1

# Mock-LLM mode. When "true", agent calls return canned responses instead
# of hitting the Portkey gateway. Use this when:
#   - you don't have a Portkey key yet
#   - you're off the corp VPN
#   - you want to demo the UI without paying for LLM tokens
# Mock outputs are clearly labeled "[MOCK]" so they cannot be mistaken
# for real Claude responses.
# Set to "false" (or remove the line) to call the real gateway.
LUMINA_USE_MOCK_LLM=true

# PoC tripwire: must be "true" for the app to generate any document.
# Check lives in app/lib/poc-guard.ts. If you don't know what this is,
# do not set it.
LUMINA_POC_MODE=true
